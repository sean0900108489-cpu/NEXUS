# API keys are entered per agent in the NEXUS Settings sidebar.
# Server env keys are intentionally not required for local live streaming.
# Production live health still requires OPENAI_API_KEY by default.
# Set NEXUS_REQUIRE_SERVER_PROVIDER_CREDENTIAL=true to enforce this outside production.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# L4 Supabase backend placeholders.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
