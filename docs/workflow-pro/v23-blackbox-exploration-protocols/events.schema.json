{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus.local/schemas/workflow-pro/blackbox-event.v1.json",
  "title": "NEXUS Workflow Pro Black-Box Exploration Event",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "runId",
    "eventId",
    "timestamp",
    "protocolId",
    "eventType",
    "summary",
    "secretRedactionStatus"
  ],
  "properties": {
    "schema": {
      "const": "nexus.workflowPro.blackbox.event.v1"
    },
    "runId": {
      "type": "string",
      "minLength": 3
    },
    "eventId": {
      "type": "string",
      "minLength": 3
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "protocolId": {
      "type": "string",
      "pattern": "^P0[1-6]$"
    },
    "phaseId": {
      "type": "string",
      "pattern": "^P0[1-6]-(core|branch-[a-z0-9-]+|collision|suspicion|synthesis|live|final|custom-[a-z0-9-]+)$"
    },
    "branchId": {
      "type": "string"
    },
    "eventType": {
      "type": "string",
      "enum": [
        "checkpoint.created",
        "checkpoint.read",
        "phase.started",
        "evidence.added",
        "no_evidence_available",
        "inference.added",
        "contradiction.added",
        "risk.added",
        "next_probe.added",
        "live_evidence.added",
        "verdict.added",
        "phase.completed",
        "final_report.created"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "secretRedactionStatus": {
      "type": "string",
      "enum": ["checked", "redacted", "not_applicable"]
    },
    "checkpointPath": {
      "type": "string"
    },
    "checkpointReadEventId": {
      "type": "string"
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence": {
      "type": "object",
      "required": ["evidenceId", "method", "confidence"],
      "properties": {
        "evidenceId": {
          "type": "string",
          "minLength": 2
        },
        "method": {
          "type": "string",
          "enum": [
            "static_read",
            "script_scan",
            "unit_test",
            "local_api_probe",
            "browser_live",
            "chrome_live",
            "computer_use_live",
            "supabase_read",
            "vercel_read",
            "github_read",
            "dry_run_model"
          ]
        },
        "sourceRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "sanitizedResult": {
          "type": "string"
        }
      }
    },
    "inference": {
      "type": "object",
      "properties": {
        "inferenceId": {
          "type": "string"
        },
        "basedOn": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "claim": {
          "type": "string"
        },
        "canBeFalsifiedBy": {
          "type": "string"
        }
      }
    },
    "contradiction": {
      "type": "object",
      "properties": {
        "contradictionId": {
          "type": "string"
        },
        "evidenceA": {
          "type": "string"
        },
        "evidenceB": {
          "type": "string"
        },
        "classification": {
          "type": "string",
          "enum": ["product-risk", "scanner-rule-risk", "inconclusive"]
        },
        "nextProbe": {
          "type": "string"
        }
      }
    },
    "verdict": {
      "type": "object",
      "properties": {
        "claim": {
          "type": "string"
        },
        "tier": {
          "type": "string",
          "enum": [
            "static-only",
            "local-live",
            "browser-live",
            "computer-use-live",
            "account-live",
            "deployment-live",
            "blocked",
            "not-yet-verified"
          ]
        },
        "requiresLiveEvidence": {
          "type": "boolean"
        },
        "requiresComputerUseEvidence": {
          "type": "boolean"
        },
        "liveEvidenceRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "nextProbe": {
      "type": "string"
    },
    "finalReportPath": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "eventType": {
            "const": "phase.started"
          }
        }
      },
      "then": {
        "required": ["phaseId", "checkpointReadEventId"]
      }
    },
    {
      "if": {
        "properties": {
          "eventType": {
            "const": "evidence.added"
          }
        }
      },
      "then": {
        "required": ["phaseId", "evidence"]
      }
    },
    {
      "if": {
        "properties": {
          "eventType": {
            "const": "live_evidence.added"
          }
        }
      },
      "then": {
        "required": ["phaseId", "evidence"]
      }
    },
    {
      "if": {
        "properties": {
          "eventType": {
            "const": "final_report.created"
          }
        }
      },
      "then": {
        "required": ["finalReportPath"]
      }
    }
  ]
}
