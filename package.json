{
  "name": "nexus-ai-ops",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check:preflight": "node scripts/check-preflight.mjs",
    "check:schema-live": "node scripts/schema-live-parity-scan.mjs",
    "check:auth-boundary": "node scripts/auth-boundary-scan.mjs && npm test -- src/lib/backend/security/auth-boundary-gate.test.ts src/lib/backend/security/route-spoof-boundary.test.ts",
    "check:auth-boundary:live": "node scripts/live-auth-boundary-probe.mjs",
    "check:output-durability": "node scripts/generated-output-durability-scan.mjs && npm test -- src/lib/backend/runtime/agent-runtime.test.ts",
    "check": "npm run check:preflight && npm run check:schema-live && npm run check:auth-boundary && npm run check:output-durability && npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "@xyflow/react": "^12.10.2",
    "framer-motion": "^12.40.0",
    "idb-keyval": "^6.2.4",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-rnd": "^10.5.3",
    "zundo": "^2.3.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "pg": "^8.21.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
