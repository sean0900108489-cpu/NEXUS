{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus.local/schemas/nexus.workflow.v1.schema.json",
  "title": "NEXUS Workflow Contract V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "id",
    "name",
    "intent",
    "successCriteria",
    "capabilityInventory",
    "nodes",
    "edges",
    "outputs",
    "brain",
    "metadata"
  ],
  "properties": {
    "schema": { "const": "nexus.workflow.v1" },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "intent": { "type": "string", "minLength": 1 },
    "successCriteria": { "type": "array", "items": { "type": "string" } },
    "capabilityInventory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["availableNodeTypes", "availableCompilers", "notAvailableYet"],
      "properties": {
        "availableNodeTypes": { "type": "array", "items": { "type": "string" } },
        "availableCompilers": { "type": "array", "items": { "type": "string" } },
        "availableArtifactPolicies": { "type": "array", "items": { "type": "string" } },
        "notAvailableYet": { "type": "array", "items": { "type": "string" } }
      }
    },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    },
    "outputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/output" }
    },
    "brain": {
      "type": "object",
      "additionalProperties": true,
      "required": ["enabled", "readBeforeRun", "mustUnderstand", "canPropose"],
      "properties": {
        "enabled": { "type": "boolean" },
        "readBeforeRun": { "type": "boolean" },
        "mustUnderstand": { "type": "array", "items": { "type": "string" } },
        "runtimeEvidence": { "type": "array", "items": { "type": "string" } },
        "canPropose": { "type": "array", "items": { "type": "string" } }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "type", "label", "purpose", "rationale", "position", "data", "limits"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string" },
        "rationale": { "type": "string" },
        "position": { "$ref": "#/$defs/position" },
        "data": { "type": "object", "additionalProperties": true },
        "limits": { "type": "array", "items": { "type": "string" } }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "source", "sourceHandle", "target", "targetHandle", "mode", "reason", "packetContract"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "sourceHandle": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "targetHandle": { "type": "string", "minLength": 1 },
        "mode": { "type": "string" },
        "reason": { "type": "string" },
        "packetContract": { "type": "object", "additionalProperties": true }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "type", "sourceNodeId"],
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "sourceNodeId": { "type": "string" }
      }
    }
  }
}

